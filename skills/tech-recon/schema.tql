# =============================================================================
# TECH-RECON NAMESPACE (trec-) - TypeDB 3.x Schema Extension
# =============================================================================
# Goal-driven technology investigation skill.
# A trec investigation organizes systems, artifacts, notes, and analyses
# into a structured knowledge graph aligned with the Alhazen Notebook Model:
#
#   Collection = trec-investigation (organizes everything)
#   Thing      = trec-system (the technology being investigated)
#   Artifact   = trec-artifact (raw evidence: pages, repos, PDFs)
#              = trec-analysis (Observable Plot visualizations)
#   Note       = trec-note (Claude's analysis and sensemaking)
#
# Namespace prefix: trec-*
# =============================================================================

define

# -----------------------------------------------------------------------------
# ATTRIBUTE TYPES - Tech-Recon Specific
# (license, format, content, cache-path, description, name, created-at are
#  already defined in the core schema -- not redefined here)
# All trec-specific attributes use the trec- prefix to avoid
# collisions with other namespaces.
# -----------------------------------------------------------------------------

attribute trec-goal-description, value string;
attribute trec-success-criteria, value string;
attribute trec-artifact-type, value string;
attribute trec-topic, value string;
attribute trec-plot-code, value string;
attribute trec-tql-query, value string;
attribute trec-pipeline-script, value string;
attribute trec-pipeline-config, value string;
attribute trec-analysis-type, value string;
attribute trec-github-url, value string;
attribute trec-star-count, value integer;
attribute trec-url, value string;
attribute trec-status, value string;
attribute trec-language, value string;
attribute trec-title, value string;
attribute trec-tag, value string;
attribute trec-iteration-number, value integer;
attribute trec-investigation-type, value string;


# -----------------------------------------------------------------------------
# RELATION TYPES
# (defined before entities so role names resolve in plays clauses)
# -----------------------------------------------------------------------------

# INVESTIGATED-IN - A system is under investigation in an investigation
relation trec-investigated-in,
    relates system,
    relates investigation;

# SOURCED-FROM - An artifact was sourced from a system or investigation
relation trec-sourced-from,
    relates artifact,
    relates source;

# ANALYSIS-OF - An analysis belongs to an investigation
relation trec-analysis-of,
    relates analysis,
    relates investigation;

# SYSTEM-PAPER-REFERENCE - Links a trec system to a scilit-paper that describes or evaluates it
relation trec-system-paper-reference,
    relates referencing-system,
    relates referenced-paper;


# -----------------------------------------------------------------------------
# ENTITY TYPES - Tech-Recon Collection
# -----------------------------------------------------------------------------

entity trec-investigation sub alh-collection,
    owns trec-investigation-type,
    owns trec-goal-description,
    owns trec-success-criteria,
    owns trec-status,
    owns trec-iteration-number,
    plays trec-investigated-in:investigation,
    plays trec-sourced-from:source,
    plays trec-analysis-of:investigation;
    # inherits plays alh-aboutness:subject from alh-identifiable-entity


# -----------------------------------------------------------------------------
# ENTITY TYPES - Tech-Recon Things
# -----------------------------------------------------------------------------

entity trec-system sub alh-domain-thing,
    owns trec-url,
    owns trec-github-url,
    owns trec-language,
    owns trec-star-count,
    owns trec-status,
    plays trec-investigated-in:system,
    plays trec-sourced-from:source,
    plays trec-system-paper-reference:referencing-system;
    # inherits plays alh-aboutness:subject from alh-identifiable-entity


# -----------------------------------------------------------------------------
# ENTITY TYPES - Tech-Recon Artifacts
# -----------------------------------------------------------------------------

entity trec-artifact sub alh-artifact,
    owns trec-artifact-type,
    owns trec-url,
    plays trec-sourced-from:artifact;

entity trec-analysis sub alh-artifact,
    owns trec-title,
    owns trec-analysis-type,
    owns trec-plot-code,
    owns trec-tql-query,
    owns trec-pipeline-script,
    owns trec-pipeline-config,
    plays trec-analysis-of:analysis;


# -----------------------------------------------------------------------------
# ENTITY TYPES - Tech-Recon Notes
# -----------------------------------------------------------------------------

entity trec-note sub alh-sensemaking-note,
    owns trec-topic,
    owns trec-tag,
    owns trec-iteration-number;
    # inherits plays alh-aboutness:note from alh-note base type


# =============================================================================
# CROSS-NAMESPACE EXTENSION
# scilit-paper (defined in scientific-literature/schema.tql, loads before this)
# participates in trec-system-paper-reference as the referenced paper.
# =============================================================================

entity scilit-paper plays trec-system-paper-reference:referenced-paper;


# =============================================================================
# END TECH-RECON NAMESPACE
# =============================================================================
